{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "openspeedtest-react",
  "main": "workers/app.ts",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "build/client"
  },
  "observability": {
    "enabled": true
  }
}
