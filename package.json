{
  "name": "openspeedtest-react",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:pages": "react-router build && node -e \"const fs = require('fs'); ['build/client/wrangler.json', 'build/server/wrangler.json'].forEach(f => fs.existsSync(f) && fs.unlinkSync(f)); if (fs.existsSync('.wrangler')) fs.rmSync('.wrangler', { recursive: true, force: true })\"",
    "dev": "react-router dev",
    "start": "wrangler pages dev build/client",
    "preview": "pnpm run build:pages && wrangler pages dev build/client",
    "deploy": "pnpm run build:pages && wrangler pages deploy build/client",
    "typecheck": "react-router typegen && wrangler types --path='./functions/types.d.ts' && tsc"
  },
  "dependencies": {
    "@react-router/cloudflare": "^8.1.0",
    "gsap": "^3.15.0",
    "isbot": "^5.1.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "wrangler": "^4.105.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^4.20260629.1",
    "@react-router/dev": "^8.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
